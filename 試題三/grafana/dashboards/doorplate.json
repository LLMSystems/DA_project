{
  "uid": "doorplate-ops",
  "title": "門牌系統維運監控",
  "tags": ["doorplate"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "爬蟲 ERROR 數（近 5 分鐘）",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=\"crawler\"} |= \"| ERROR |\" [5m]))",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API 查無資料數（近 5 分鐘）",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=\"api\"} |= \"empty_result\" [5m]))",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "logs",
      "title": "試題一 爬蟲即時 Log",
      "gridPos": { "h": 11, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"crawler\"}"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "試題二 API 查詢與通知 Log",
      "gridPos": { "h": 11, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"api\"}"
        }
      ]
    }
  ]
}
